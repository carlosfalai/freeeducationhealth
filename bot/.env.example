# Copy this file to .env in the same folder and fill in your own values.
# Nothing in this project reads a shared/hosted credential -- every
# self-hoster brings their own Telegram bot token and AI provider keys.
#
# EASIEST: don't edit this by hand -- run `node bot/setup.cjs`, an
# interactive wizard that asks whether you use a coding agent, collects
# your own OpenAI (ChatGPT) / Google Gemini / DeepSeek keys with the echo
# hidden, and writes a valid .env for you. This file documents the same
# variables for anyone who prefers to edit them directly.

# Telegram bot token from @BotFather (https://t.me/BotFather -> /newbot).
BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated AI providers for core/'s panel: name:model:apiKeyEnvVar[:baseUrl]
# core/ never reads these env vars directly -- bot/config.cjs resolves them
# into a PanelConfig (see ../core/INTERFACE.md). Supported provider names:
# anthropic, openai, gemini, deepseek, openai-compatible (local/Ollama).
# List a multi-vendor panel so DIFFERENT companies cross-check each case:
PANEL_PROVIDERS=openai:gpt-4o-mini:OPENAI_API_KEY,gemini:gemini-2.5-flash:GEMINI_API_KEY,deepseek:deepseek-chat:DEEPSEEK_API_KEY

# How many independent models must answer per recommendation (must be >= 2;
# see ../core/INTERFACE.md's note that a single-model answer has no
# divergence detection). Set it to the number of providers above, up to 3.
PANEL_SIZE=3

# Style guide applied to plain-language output. "generic" is always available
# pre-PHI-scrub-gate; see ../core/persona/.
PERSONA_STYLE=generic

# Fallback locale (BCP-47) used when a chat gives no language hint.
BOT_LOCALE=en

# --- Provider credentials --------------------------------------------------
# Add one line per apiKeyEnvVar referenced in PANEL_PROVIDERS above. Only
# fill in the ones you actually configured a provider for. Each key is your
# own, obtained directly from that provider:
#   OpenAI (ChatGPT)  https://platform.openai.com/api-keys
#   Google Gemini     https://aistudio.google.com/apikey
#   DeepSeek          https://platform.deepseek.com/api_keys
#   Anthropic (Claude) https://console.anthropic.com/settings/keys
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# For a local/Ollama model via the "openai-compatible" provider, set
# baseUrl in PANEL_PROVIDERS (e.g. ...:openai-compatible:llama3:LOCAL_API_KEY:http://localhost:11434/v1)
# and LOCAL_API_KEY can be any placeholder string most local servers ignore.
# A panel of two DIFFERENT local models keeps everything on your machine.
