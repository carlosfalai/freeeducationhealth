# Copy this file to .env in the same folder and fill in your own values.
# Nothing in this project reads a shared/hosted credential -- every
# self-hoster brings their own Telegram bot token and AI provider keys.

# Telegram bot token from @BotFather (https://t.me/BotFather -> /newbot).
BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated AI providers for core/'s panel: name:model:apiKeyEnvVar[:baseUrl]
# core/ never reads these env vars directly -- bot/config.cjs resolves them
# into a PanelConfig (see ../core/INTERFACE.md). List each provider's
# apiKeyEnvVar below with its real value.
PANEL_PROVIDERS=anthropic:claude-sonnet-5:ANTHROPIC_API_KEY,deepseek:deepseek-chat:DEEPSEEK_API_KEY

# Minimum independent model responses required per recommendation (must be >= 2;
# see ../core/INTERFACE.md's note that a single-model answer has no
# divergence detection).
PANEL_SIZE=2

# Style guide applied to plain-language output. "generic" is always available
# pre-PHI-scrub-gate; see ../core/persona/.
PERSONA_STYLE=generic

# Fallback locale (BCP-47) used when a chat gives no language hint.
BOT_LOCALE=en

# --- Provider credentials --------------------------------------------------
# Add one line per apiKeyEnvVar referenced in PANEL_PROVIDERS above. Only
# fill in the ones you actually configured a provider for.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# For a local/Ollama model via the "openai-compatible" provider, set
# baseUrl in PANEL_PROVIDERS (e.g. ...:openai-compatible:llama3:LOCAL_API_KEY:http://localhost:11434/v1)
# and LOCAL_API_KEY can be any placeholder string most local servers ignore.
