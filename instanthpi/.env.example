# instanthpi/.env.example
#
# Copy this file to instanthpi/.env and fill in YOUR OWN credentials. This
# front-end has no shared/hosted infrastructure -- every self-hoster brings
# their own Spruce account, their own AI provider keys (used via ../core/),
# and their own SRFax account. Never commit the real .env file.

# --- Carousel review server (instanthpi/carousel/cards-server.cjs) ---
# Mandatory. The review server refuses to start without this. Pick a PIN only
# you know; it gates the local HTTP view of patient case cards.
CAROUSEL_PIN=your-pin-here
# Optional, defaults to 4747.
CAROUSEL_PORT=4747

# --- Spruce Health API (instanthpi/spruce/client.cjs) ---
# Your own Spruce API bearer token (Spruce Health dashboard -> API/integrations).
SPRUCE_API_TOKEN=your-spruce-api-token-here
# Optional override, defaults to https://api.sprucehealth.com. Verify the
# current base URL / endpoint paths against your account's API reference --
# see the ADAPT-ME notes in spruce/client.cjs.
SPRUCE_BASE_URL=https://api.sprucehealth.com

# --- SRFax outbound fax (instanthpi/fax/send.cjs) ---
# Your own SRFax account credentials (SRFax dashboard -> Developers -> API).
SRFAX_ACCESS_ID=your-srfax-account-number-here
SRFAX_PWD=your-srfax-password-here
# The fax number SRFax should show as the sender (digits only, no formatting).
SRFAX_CALLER_ID=5555550100

# --- Optional: physician's own signature image for PDF form-filling ---
# instanthpi/pdf/fill.py can stamp a signature image onto a form field, but
# ONLY if you supply your own file here. Never commit this file or point it
# at anything checked into git. Leave unset to always sign printouts by hand.
SIGNATURE_IMAGE_PATH=

# --- core/ AI panel providers ---
# These are consumed by core/ (see core/INTERFACE.md), not read directly by
# instanthpi/ code, but you'll need at least panelSize independent providers
# configured for getRecommendation() to succeed. Example provider keys:
ANTHROPIC_API_KEY=your-anthropic-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
OPENAI_API_KEY=your-openai-key-here

# Optional default jurisdiction hint forwarded to core/'s billingSuggestions
# generation for this physician's practice, e.g. "CA-QC", "KE", "generic".
INSTANTHPI_JURISDICTION=generic
